    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/pg": "^8.6.7",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "tsx": "^4.21.0"
  }
}